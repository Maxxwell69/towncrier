DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
NEXT_PUBLIC_APP_URL="https://towncrier-production.up.railway.app"

# Generate strong random values before deploy.
SESSION_SECRET="replace-with-a-long-random-session-secret"
ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"

# Seeded admin account.
ADMIN_EMAIL="admin@towncrier.local"
ADMIN_PASSWORD="ChangeMe123!"

# Claude blog generation.
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-4-6"

# Stock image search.
PEXELS_API_KEY=""

# Optional legacy GoHighLevel publishing adapter.
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
GHL_API_VERSION="2021-07-28"
GHL_CREATE_BLOG_POST_PATH="/blogs/posts"

# Facebook page posting (OAuth).
# Create a Meta app at https://developers.facebook.com/apps/
# Add "Facebook Login for Business" product, enable pages_manage_posts permission.
# Set the redirect URI to: https://<your-domain>/api/auth/facebook/callback
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Automated daily blog generation.
# Set to a random secret, then configure your cron caller to send:
#   Authorization: Bearer <CRON_SECRET>
# to GET https://<your-domain>/api/cron/run
# Leave blank to disable auth (not recommended in production).
CRON_SECRET=""

# Signup control.
ALLOW_PUBLIC_SIGNUP="false"
