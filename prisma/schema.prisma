generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NetworkStatus {
  active
  paused
}

enum BlogPostStatus {
  draft
  publishing
  published
  failed
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("admin")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  networks     Network[]
}

model Network {
  id                         String        @id @default(cuid())
  ownerId                    String
  name                       String
  ghlLocationId              String?
  ghlCompanyId               String?
  credentialType             String        @default("manual")
  encryptedCredentialPayload String
  status                     NetworkStatus @default(active)
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  blogConfig BlogConfig?
  posts      BlogPost[]

  @@index([ownerId])
}

model BlogConfig {
  id          String   @id @default(cuid())
  networkId   String   @unique
  blogId      String
  defaultTopic String
  categories  String[]
  postingDays String[]
  imageStyle  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id              String         @id @default(cuid())
  networkId       String
  topic           String
  title           String
  slug            String
  excerpt         String
  bodyMarkdown    String
  categories      String[]
  imagePrompt     String?
  imageUrl        String?
  status          BlogPostStatus @default(draft)
  ghlPostId       String?
  publishResponse Json?
  errorMessage    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId])
  @@index([status])
}
