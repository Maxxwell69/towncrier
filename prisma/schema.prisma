generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NetworkStatus {
  active
  paused
}

enum BlogPostStatus {
  draft
  publishing
  published
  failed
}

enum PublishPlatform {
  vercel
  ghl
  wordpress
}

enum BlogPostSource {
  claude
  manual
  topic_queue
}

enum ImageProvider {
  manual
  pexels
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("admin")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  networks     Network[]
}

model Network {
  id                         String          @id @default(cuid())
  ownerId                    String
  name                       String
  slug                       String          @unique @default(cuid())
  domain                     String?
  platform                   PublishPlatform @default(vercel)
  locationName               String?
  city                       String?
  state                      String?
  serviceArea                String?
  authorName                 String?
  authorTitle                String?
  authorBio                  String?
  authorImageUrl             String?
  siteApiKeyHash             String?
  siteApiKeyHint             String?
  revalidateUrl              String?
  revalidateSecret           String?
  ghlLocationId              String?
  ghlCompanyId               String?
  credentialType             String          @default("manual")
  encryptedCredentialPayload String?
  status                     NetworkStatus   @default(active)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  blogConfig BlogConfig?
  posts      BlogPost[]
  topics     Topic[]

  @@index([ownerId])
}

model Topic {
  id          String    @id @default(cuid())
  networkId   String
  title       String
  description String?
  category    String?
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  useCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  network Network    @relation(fields: [networkId], references: [id], onDelete: Cascade)
  posts   BlogPost[]

  @@index([networkId])
  @@index([isActive])
}

model BlogConfig {
  id                 String    @id @default(cuid())
  networkId          String    @unique
  blogId             String?
  defaultTopic       String
  categories         String[]
  postingDays        String[]
  postingTime        String    @default("08:00")
  timezone           String    @default("America/New_York")
  imageStyle         String?
  automationEnabled  Boolean   @default(false)
  autoPublishEnabled Boolean   @default(false)
  autoImageEnabled   Boolean   @default(true)
  lastAutoRunDate    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  network Network @relation(fields: [networkId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id               String         @id @default(cuid())
  networkId        String
  topicId          String?
  topic            String
  title            String
  slug             String
  excerpt          String
  bodyMarkdown     String
  bodyHtml         String?
  categories       String[]
  seoTitle         String?
  seoDescription   String?
  canonicalUrl     String?
  imagePrompt      String?
  imageUrl         String?
  featuredImageAlt String?
  imageProvider    ImageProvider  @default(manual)
  imageCredit      String?
  imageSourceUrl   String?
  source           BlogPostSource @default(claude)
  scheduledFor     DateTime?
  status           BlogPostStatus @default(draft)
  ghlPostId        String?
  externalPostId   String?
  publishedTo      String?
  publishResponse  Json?
  errorMessage     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  publishedAt      DateTime?

  network         Network          @relation(fields: [networkId], references: [id], onDelete: Cascade)
  sourceTopic     Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  imageCandidates ImageCandidate[]

  @@unique([networkId, slug])
  @@index([networkId])
  @@index([topicId])
  @@index([status])
}

model ImageCandidate {
  id              String        @id @default(cuid())
  postId          String
  provider        ImageProvider @default(pexels)
  imageUrl        String
  photographer    String?
  photographerUrl String?
  sourceUrl       String?
  altText         String?
  createdAt       DateTime      @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}
